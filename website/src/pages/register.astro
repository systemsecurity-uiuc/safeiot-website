---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Register — SafeIoT Hackathon" description="Register for the SafeIoT Hackathon.">

  <section class="max-w-2xl mx-auto px-6 py-24">
    <a href="/" class="text-sm text-indigo-600 hover:underline mb-8 inline-block">← Back to home</a>

    <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Register</h1>
    <p class="text-gray-500 mb-10">Sign up for the SafeIoT Hackathon. We'll be in touch with details closer to the event.</p>

    <form class="space-y-6">

      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
          <input type="text" placeholder="Jane"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
          <input type="text" placeholder="Smith"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" placeholder="jane@example.com"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Affiliation</label>
        <input type="text" placeholder="University / Company"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
        <select class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="" disabled selected>Select your role</option>
          <option>Undergraduate Student</option>
          <option>Graduate Student</option>
          <option>Researcher / Postdoc</option>
          <option>Industry Engineer</option>
          <option>Other</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Participating as</label>
        <select class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="" disabled selected>Select</option>
          <option>Solo</option>
          <option>Part of a team</option>
          <option>Looking for a team</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Brief background or motivation <span class="text-gray-400 font-normal">(optional)</span></label>
        <textarea rows="4" placeholder="Tell us a bit about your background and what you hope to work on..."
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 resize-none"></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-500 transition-colors"
      >
        Submit Registration
      </button>

    </form>
  </section>

  <footer class="border-t border-gray-200 px-6 py-8 text-center text-sm text-gray-400">
    © 2025 FHS-IoT / SafeIoT. All rights reserved.
  </footer>

</Layout>
